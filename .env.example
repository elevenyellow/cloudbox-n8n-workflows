# n8n API Configuration
# Copy this file to .env and fill in your values

# n8n API endpoint (Tailscale-only access)
N8N_API_URL=https://n8n.rola.dev/api/v1

# n8n API key (generate in n8n UI: Settings → n8n API → Create API Key)
# Format: n8n_api_<32-character-alphanumeric>
N8N_API_KEY=your_api_key_here
